# Backend API host (no /api suffix — routes append /api/... automatically)
#
# Local dev: leave empty so Vite proxies /api -> http://localhost:5000
VITE_API_URL=
#
# Production (Vercel): set in Project Settings -> Environment Variables, or use .env.production:
# VITE_API_URL=https://dsatro-backend.onrender.com

# ── Supabase (backend only) ─────────────────────────────────────
# Add these to backend/.env — NOT the frontend:
# SUPABASE_URL=https://YOUR_REF.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_secret_key
# SUPABASE_STORAGE_BUCKET=course-images
